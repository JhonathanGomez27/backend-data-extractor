@BASIC_AUTH = Basic QUFERDpBREREMjAyNg==


##################################################
### ADMIN ENDPOINTS (JWT Authentication)
##################################################

### 1. Create Model (Admin)
POST {{API_URL}}/api/models
Content-Type: application/json
Authorization: Bearer {{TOKEN}}

{
  "name": "Menciona la marca al contestar",
  "description": "Detectar si se menciona la marca del producto o servicio en la conversación.",
  "modelTypeId": "{{MODEL_TYPE_ID}}",
  "clientId": "{{CLIENT_ID}}",
  "data": {
    "template": {
      "templateName": "deteccion_marca_producto_servicio",
      "modules": [
        {
          "key": "entidades",
          "enabled": true,
          "config": {
            "extraer": true,
            "tipos": [
              "marca"
            ],
            "reglas": {
              "debe_mencionarse": true,
              "ventana_inicial_segundos": 0,
              "coincidencia": {
                "modo": "parcial",
                "case_sensitive": false
              },
              "sinonimos": []
            }
          }
        }
      ]
    }
  } 
}


### 2. List All Models with Pagination (Admin)
GET {{API_URL}}/api/models?page=1&limit=20
Authorization: Bearer {{TOKEN}}


### 3. List Models with Search (Admin)
GET {{API_URL}}/api/models?page=1&limit=10&searchText=marca
Authorization: Bearer {{TOKEN}}


### 4. List Models filtered by Client ID (Admin)
GET {{API_URL}}/api/models?clientId={{CLIENT_ID}}&page=1&limit=10
Authorization: Bearer {{TOKEN}}


### 5. Get Model by ID (Admin)
GET {{API_URL}}/api/models/{{MODEL_ID}}
Authorization: Bearer {{TOKEN}}


##################################################
### CLIENT ENDPOINTS (Basic Authentication)
##################################################

### 6. List Models for Client (Basic Auth)
GET {{API_URL}}/api/models/client/models
Authorization: {{BASIC_AUTH}}


### 7. List Models for Client with Pagination (Basic Auth)
GET {{API_URL}}/api/models/client/models?page=1&limit=10
Authorization: {{BASIC_AUTH}}


### 8. List Models for Client with Search (Basic Auth)
GET {{API_URL}}/api/models/client/models?searchText=template&page=1&limit=20
Authorization: {{BASIC_AUTH}}


### 9. Extract Model for Client
POST {{API_URL}}/api/models/client/extract
Content-Type: application/json
Authorization: {{BASIC_AUTH}}

{
  "transcripcion": [
    {
      "speaker": "agent",
      "init_time": "0,660",
      "end_time": "15,360",
      "text": "Señor Leandro Burgueño, por su seguridad, grabamos la conversación para que quede constancia de su interés en contratar el suministro de energía con Endesa Energía SAU, con domicilio en Calle Ribera de la Oira, número 6028042, Madrid. ¿Está de acuerdo, verdad?"
    },
    {
      "speaker": "client",
      "init_time": "18,120",
      "end_time": "18,300",
      "text": "Sí."
    },
    {
      "speaker": "agent",
      "init_time": "18,900",
      "end_time": "46,680",
      "text": "Le informamos de que su llamada podrá ser grabada por motivos de seguridad y que Endesa Energía tratará sus datos personales como responsables del tratamiento. Si desea obtener más información sobre la política de protección de datos de Endesa Energía, incluida la forma de ejercer sus derechos, puede consultar la web www.endesa-clientes.com. Conforme a los datos que nos has facilitado el 28 de enero del 2026, cuando son las 19:19, usted, Leandro Burgueño, con"
    },
    {
      "speaker": "agent",
      "init_time": "47,760",
      "end_time": "56,100",
      "text": "NIE Z1913270, C de Cádiz, como titular del punto de suministro, autoriza"
    },
    {
      "speaker": "agent",
      "init_time": "56,940",
      "end_time": "64,380",
      "text": "a Endesa a enviarle por SMS al teléfono móvil 613-962-900"
    },
    {
      "speaker": "agent",
      "init_time": "65,220",
      "end_time": "86,880",
      "text": "su oferta de contratación de la tarifa Luz One. Esta oferta requiere tener factura electrónica al pago domiciliado y que todas las sesiones se realicen a través de la web o app de Endesa. Por tener contratada la tarifa One 2.0 TD, usted disfrutará de un único precio término de energía de 0,13272375 euros kilovatio hora, término de potencia punta y valle de 2,74."
    },
    {
      "speaker": "agent",
      "init_time": "87,780",
      "end_time": "92,400",
      "text": "Al mes, disfrutarás de un 10% de descuento base sobre el término de energía durante un año,"
    },
    {
      "speaker": "agent",
      "init_time": "93,360",
      "end_time": "102,180",
      "text": "quedándote en 0,119, válido para nuevas contrataciones. La aplicación de los descuentos está sujeta a la activación de productos contratados, impuestos no incluidos."
    },
    {
      "speaker": "agent",
      "init_time": "103,740",
      "end_time": "137,460",
      "text": "Actualización de precios: primero de enero, con IPC, se aplicarán las revisiones de componentes regulados aprobados normativamente. Los precios de estas tarifas se actualizarán conforme el IPC y se aplicarán las revisiones de componentes regulados aprobados normativamente para el CUPS de luz ES0031, 104606002002XW0F, situado en la calle Berilio 86, Roquetas del Mar, piso bajo, puerta 301, 04740, Roquetas del Mar, Almería. ¿Es correcto, verdad?"
    },
    {
      "speaker": "client",
      "init_time": "139,380",
      "end_time": "140,220",
      "text": "Sí, es correcto."
    },
    {
      "speaker": "agent",
      "init_time": "140,700",
      "end_time": "152,160",
      "text": "Como ha aceptado darse de alta en la factura electrónica, comenzaremos a emitir la factura una vez esté activa. Su correo electrónico con Endesa es leandroelburgue@yahoo.com.ar."
    },
    {
      "speaker": "agent",
      "init_time": "153,000",
      "end_time": "167,820",
      "text": "El número de cuenta donde desea domiciliar el pago es ES6100493786742014224948, de la cual el titular coincide con el punto de suministro, ¿verdad?"
    },
    {
      "speaker": "client",
      "init_time": "170,340",
      "end_time": "171,300",
      "text": "No, el titular"
    },
    {
      "speaker": "client",
      "init_time": "173,160",
      "end_time": "173,520",
      "text": "de esa"
    },
    {
      "speaker": "client",
      "init_time": "176,160",
      "end_time": "178,200",
      "text": "cuenta es Romina Menceys."
    },
    {
      "speaker": "agent",
      "init_time": "178,680",
      "end_time": "180,060",
      "text": "Pero la cuenta es compartida."
    },
    {
      "speaker": "client",
      "init_time": "184,680",
      "end_time": "185,700",
      "text": "Sí, así está nombradita."
    },
    {
      "speaker": "agent",
      "init_time": "185,760",
      "end_time": "187,380",
      "text": "Pero la cuenta es compartida, ¿correcto?"
    },
    {
      "speaker": "client",
      "init_time": "189,600",
      "end_time": "189,780",
      "text": "Sí."
    },
    {
      "speaker": "agent",
      "init_time": "190,320",
      "end_time": "191,760",
      "text": "Vale. Entonces continúo."
    },
    {
      "speaker": "agent",
      "init_time": "192,600",
      "end_time": "192,840",
      "text": "Una vez que"
    },
    {
      "speaker": "agent",
      "init_time": "194,820",
      "end_time": "215,640",
      "text": "reciba el SMS, tan solo debe contestarnos con la palabra \"Sí\". Y según recibamos su contestación, tramitaremos con su distribuidora devolución de esa distribución eléctrica SL, para que pueda beneficiarse cuanto antes de los descuentos que le hemos enviado y comentado. Una vez nos haya aceptado su distribuidora el cambio con el contrato con su anterior comercializadora, quedará extinguido. ¿Está de acuerdo, verdad?"
    },
    {
      "speaker": "client",
      "init_time": "217,320",
      "end_time": "218,160",
      "text": "Sí, estoy de acuerdo."
    },
    {
      "speaker": "agent",
      "init_time": "218,460",
      "end_time": "231,120",
      "text": "Le recordamos que si era de baja dicho contrato, se anularían los descuentos que se le aplican por la tarifa contratada. Le recuerdo que en breve recibirá la copia de sus contratos de energía con las condiciones del producto que están además disponibles en nuestra página web"
    },
    {
      "speaker": "agent",
      "init_time": "232,020",
      "end_time": "236,460",
      "text": "3ws.endesa-clientes.com. A partir de la fecha de celebración"
    },
    {
      "speaker": "agent",
      "init_time": "238,740",
      "end_time": "254,760",
      "text": "del contrato, dispone de 14 días naturales para ejercer su derecho de existimiento, dirigiéndose por escrito a Endesa Energía SAU, al apartado postal 81808080, Barcelona, siempre que el suministro tenga cena de doméstico. A estos efectos, le interesa que el suministro"
    },
    {
      "speaker": "agent",
      "init_time": "255,960",
      "end_time": "260,580",
      "text": "pueda dar comienzo dentro del plazo señalado de existimiento, conforme a la"
    },
    {
      "speaker": "agent",
      "init_time": "261,720",
      "end_time": "263,580",
      "text": "actual normativa de consumo. ¿Sí?"
    },
    {
      "speaker": "client",
      "init_time": "265,380",
      "end_time": "265,560",
      "text": "Sí."
    },
    {
      "speaker": "agent",
      "init_time": "266,220",
      "end_time": "281,700",
      "text": "Te informamos de que no contratamos a clientes con bono social, por lo que si reúnes los requisitos, no podemos ofrecértelo. Si en un futuro cumpliera los requisitos para acceder a él, podrá resolver anticipadamente el contrato con nosotros sin penalización y contratar con una comercializadora de referencia."
    },
    {
      "speaker": "agent",
      "init_time": "283,860",
      "end_time": "312,360",
      "text": "Para cualquier consulta en relación con este contrato, puede contactar con Endesa a través del teléfono 807-609-09, a través de 3ws.endesa-clientes.com, a la dirección atención al cliente@endesaonline.com o a cualquiera de nuestras oficinas comerciales o puntos de servicio Endesa. Consciente que Endesa comunica sus datos personales a terceras empresas relacionadas con los sectores de hogar, seguros, automoción, servicios financieros y ocios basados en sus intereses. ¿Sí o no?"
    },
    {
      "speaker": "client",
      "init_time": "313,800",
      "end_time": "313,860",
      "text": "No."
    },
    {
      "speaker": "agent",
      "init_time": "315,540",
      "end_time": "315,600",
      "text": "Vale."
    }
  ]
}


### 10. Extract Model with Multiple Models
POST {{API_URL}}/api/models/client/extract
Content-Type: application/json
Authorization: {{BASIC_AUTH}}

{
  "transcripcion": {
    "segments": [
      {
        "speaker": "agent",
        "text": "Bienvenido a nuestra empresa, soy María.",
        "start": 0,
        "end": 3
      }
    ]
  },
  "config_global": {
    "enableValidation": true
  }
}


##################################################
### EXAMPLES WITH REAL VALUES
##################################################

### Example 1: Create Sentiment Analysis Model
POST {{API_URL}}/api/models
Content-Type: application/json
Authorization: Bearer {{TOKEN}}

{
  "name": "Análisis de Sentimiento",
  "description": "Detecta el sentimiento general de la conversación (positivo, negativo, neutral)",
  "modelTypeId": "{{MODEL_TYPE_ID}}",
  "clientId": "{{CLIENT_ID}}",
  "data": {
    "template": {
      "templateName": "sentiment_analysis",
      "modules": [
        {
          "key": "sentiment",
          "enabled": true,
          "config": {
            "detectar": true,
            "niveles": ["positivo", "neutral", "negativo"],
            "umbral_confianza": 0.7
          }
        }
      ]
    }
  }
}


### Example 2: Create Entity Detection Model
POST {{API_URL}}/api/models
Content-Type: application/json
Authorization: Bearer {{TOKEN}}

{
  "name": "Detección de Entidades",
  "description": "Extrae marcas, productos y empresas mencionadas",
  "modelTypeId": "{{MODEL_TYPE_ID}}",
  "clientId": "{{CLIENT_ID}}",
  "data": {
    "template": {
      "templateName": "entity_extraction",
      "modules": [
        {
          "key": "entidades",
          "enabled": true,
          "config": {
            "extraer": true,
            "tipos": ["marca", "producto", "empresa"],
            "reglas": {
              "debe_mencionarse": false,
              "ventana_inicial_segundos": null
            }
          }
        }
      ]
    }
  }
}


### Example 3: Extract with Real Transcription
POST {{API_URL}}/api/models/client/extract?lang=es&sentiment_model=abc-123&entity_model=def-456
Content-Type: application/json
Authorization: {{BASIC_AUTH}}

{
  "transcripcion": {
    "segments": [
      {
        "speaker": "agent",
        "text": "Buenos días, le habla María de TechCorp. ¿En qué puedo ayudarle hoy?",
        "start": 0,
        "end": 4.5
      },
      {
        "speaker": "client",
        "text": "Hola, estoy interesado en el iPhone 15 Pro que vi en su catálogo.",
        "start": 5,
        "end": 9.2
      },
      {
        "speaker": "agent",
        "text": "Excelente elección. El iPhone 15 Pro está disponible en varios colores y capacidades.",
        "start": 10,
        "end": 15
      }
    ],
    "duration": 180,
    "metadata": {
      "callId": "CALL-2025-001",
      "date": "2025-11-10T10:30:00Z",
      "channel": "phone"
    }
  },
  "config_global": {
    "language": "es",
    "includeTimestamps": true,
    "outputFormat": "detailed",
    "confidence_threshold": 0.75
  }
}
